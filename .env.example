# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stadiummind?schema=public"

# Redis Cache
REDIS_URL="redis://localhost:6379"

# Security & JWT
JWT_ACCESS_SECRET="super-secret-access-token-key-2026-fifa"
JWT_REFRESH_SECRET="super-secret-refresh-token-key-2026-fifa"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Server Port
PORT=5000

# Gemini API Key
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# Environment
NODE_ENV="development"
